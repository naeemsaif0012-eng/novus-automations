{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ua = process.env.npm_config_user_agent || ''; if (ua.startsWith('pnpm/')) process.exit(0);\"",
    "install:frontend": "npm --prefix artifacts/novus install",
    "postinstall": "npm run install:frontend",
    "build": "npm run install:frontend && npm --prefix artifacts/novus run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm --prefix artifacts/novus run typecheck"
  },
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "typescript": "~5.9.3"
  }
}
